modules = ["nodejs-20", "web"]
run = "npm run dev"

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "static"
publicDir = "dist"

[workflows]
runButton = "Dev Server"

[[workflows.workflow]]
name = "Dev Server"
author = 44568494
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[[ports]]
localPort = 3000
externalPort = 3002

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 4173
externalPort = 3000

[[ports]]
localPort = 4174
externalPort = 3001

[[ports]]
localPort = 4175
externalPort = 3003
